{
  "env": "test",
  "telegram": {
    "api_id": 12345678,
    "api_hash": "YOUR_TELEGRAM_API_HASH",
    "session_name": "tgpost_session"
  },
  "bots": {
    "sender_bot_token": "YOUR_TELEGRAM_BOT_TOKEN",
    "alert_bot_token": "YOUR_ALERT_BOT_TOKEN"
  },
  "openrouter": {
    "api_key": "YOUR_OPENROUTER_API_KEY",
    "model": "google/gemini-2.5-flash",
    "prompt_file": "prompt.txt",
    "base_url": "https://openrouter.ai/api/v1/chat/completions",
    "app_name": "tgpost",
    "site_url": "",
    "temperature": 0.4,
    "max_tokens": 4000
  },
  "image_search": {
    "enabled": true,
    "provider": "pixabay",
    "api_key": "YOUR_PIXABAY_API_KEY",
    "short_posts_only": true,
    "min_post_chars": 0,
    "max_post_chars": 1000,
    "daily_photo_post": {
      "enabled": true,
      "index": 3,
      "max_post_chars": 1000
    },
    "lang": "ru",
    "image_type": "photo",
    "orientation": "horizontal",
    "category": "business",
    "safesearch": true,
    "order": "popular",
    "per_page": 5
  },
  "image_storage": {
    "enabled": true,
    "download": true,
    "dir": "generated_media"
  },
  "content": {
    "channels": [
      "@channel_one",
      "@channel_two"
    ],
    "cta": {
      "enabled": true,
      "text": "Записаться",
      "url": "https://t.me/your_username"
    },
    "stories": {
      "enabled": true,
      "caption": "",
      "append_title_from_post": false,
      "use_first_post_only": true,
      "period": 86400,
      "background_image_path": "story_background.jpg",
      "background_image_url": "",
      "post_area": {
        "x": 50,
        "y": 43,
        "w": 86,
        "h": 48,
        "rotation": 0,
        "radius": 16
      }
    }
  },
  "environments": {
    "test": {
      "channel_chat_id": "@test_channel_username",
      "story_chat_id": "@test_channel_username"
    },
    "prod": {
      "channel_chat_id": "@prod_channel_username",
      "story_chat_id": "@prod_channel_username"
    }
  },
  "alerts": {
    "enabled": true,
    "chat_ids": [
      "@your_username",
      "@manager_username"
    ]
  },
  "paths": {
    "state_path": "state.json",
    "output_dir": "exports",
    "archive_exports_dir": "archive_exports",
    "output_prefix": "tgposts",
    "md_output_dir": "generated_posts",
    "sent_posts_dir": "sent_posts",
    "failed_posts_dir": "failed_posts",
    "raw_ai_dir": "raw_ai_responses",
    "media_dir": "generated_media",
    "sent_media_dir": "sent_media",
    "failed_media_dir": "failed_media",
    "log_dir": "logs"
  },
  "runtime": {
    "timezone": "Europe/Istanbul",
    "log_level": "INFO"
  },
  "validation": {
    "min_posts": 3,
    "max_posts": 5,
    "target_min_posts": 3,
    "min_chars": 300,
    "photo_caption_limit": 1000,
    "max_chars": 3500
  },
  "retention": {
    "enabled": true,
    "archive_exports_days": 30,
    "sent_posts_days": 30,
    "sent_media_days": 30,
    "raw_ai_days": 14,
    "failed_posts_days": 60,
    "failed_media_days": 60,
    "logs_days": 30
  },
  "locks": {
    "get_posts": "locks/get_posts.lock",
    "send_posts": "locks/send_posts.lock",
    "send_story": "locks/send_story.lock",
    "cleanup": "locks/cleanup.lock"
  }
}
